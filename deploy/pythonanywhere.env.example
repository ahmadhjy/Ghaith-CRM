# Copy to pythonanywhere.env on the PythonAnywhere server (never commit the real file).
#   cp deploy/pythonanywhere.env.example deploy/pythonanywhere.env
#
# Then edit paths to match your account.

# ── PythonAnywhere account ──────────────────────────────────────────────────
PA_USERNAME="ghaithtravel"
PA_DOMAIN="ghaithtravel.pythonanywhere.com"
PA_WSGI_FILE="/var/www/ghaithtravel_pythonanywhere_com_wsgi.py"

# ── Project paths (must match WSGI: project_home = /home/ghaithtravel/ghaithleads)
PROJECT_DIR="/home/ghaithtravel/ghaithleads"
VENV_DIR="/home/ghaithtravel/djangenv"

# PythonAnywhere Web tab → Static files / Media (already configured on your account)
STATIC_SERVE_DIR="/home/ghaithtravel/ghaithleads/static"
MEDIA_DIR="/home/ghaithtravel/ghaithleads/media"

# Django settings module (must match WSGI: ghaithleads.settings)
DJANGO_SETTINGS_MODULE="ghaithleads.settings"

# ── Git ─────────────────────────────────────────────────────────────────────
GIT_REMOTE="origin"
GIT_BRANCH="main"
GIT_REPO_URL="https://github.com/ahmadhjy/Ghaith-CRM.git"

# Repo uses package name "system"; production WSGI uses "ghaithleads".
# Set to "yes" to copy system/* → ghaithleads/* after pull (keeps ghaithleads/settings.py).
SYNC_SYSTEM_TO_GHAITHLEADS="yes"
REPO_SYSTEM_DIR="system"
PROD_SETTINGS_PACKAGE="ghaithleads"

# ── Backups (stored outside the git tree) ───────────────────────────────────
BACKUP_ROOT="/home/ghaithtravel/deploy-backups"

# ── Reload method: touch | api | both
RELOAD_METHOD="touch"

# Optional: only needed if RELOAD_METHOD includes "api"
# On PythonAnywhere consoles, $API_TOKEN is often already set.
# PA_API_TOKEN=""

# ── Safety ──────────────────────────────────────────────────────────────────
# Abort if git working tree has uncommitted changes (recommended: yes)
REQUIRE_CLEAN_GIT="no"

# Run collectstatic after migrate (yes for this project — STATIC_ROOT is configured)
RUN_COLLECTSTATIC="yes"
